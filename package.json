			"dist/credentials/mlflowAiGatewayApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/LmChatMlflowAiGateway/LmChatMlflowAiGateway.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.31.0",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"ai-node-sdk": "*",
		"n8n-workflow": "*"
	}
}
